{
  "name": "425-raidmon",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "node scripts/start-expo-lan.mjs",
    "start:lan": "node scripts/start-expo-lan.mjs",
    "start:tunnel": "cross-env EXPO_NO_DEPENDENCY_VALIDATION=1 expo start --port 8082 --host tunnel",
    "start:offline": "node scripts/start-expo-lan.mjs --offline",
    "start:online": "node scripts/start-expo-lan.mjs",
    "android": "cross-env EXPO_NO_DEPENDENCY_VALIDATION=1 expo start --android",
    "ios": "cross-env EXPO_NO_DEPENDENCY_VALIDATION=1 expo start --ios",
    "web": "cross-env EXPO_NO_DEPENDENCY_VALIDATION=1 expo start --web",
    "build": "expo export --platform web"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.10.1",
    "expo": "~54.0.32",
    "expo-clipboard": "^55.0.13",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "^55.0.13",
    "expo-print": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-status-bar": "~3.0.9",
    "firebase": "^12.8.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.0.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "cross-env": "^10.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
