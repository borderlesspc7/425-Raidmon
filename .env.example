# Copie para .env e preencha (não commite o .env).
# Expo expõe apenas variáveis com prefixo EXPO_PUBLIC_ no bundle do app.

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
# Opcional — usado pelo Google Analytics (web)
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Região das Cloud Functions de pagamento Asaas (deve bater com functions/index.js)
EXPO_PUBLIC_FIREBASE_FUNCTIONS_REGION=southamerica-east1
