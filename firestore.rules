rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isWorkshop() {
      return isAuthenticated() && getUserRole() == 'workshop';
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function getUserPlan() {
      return getUserData().plan;
    }

    function isPremiumOrEnterprise() {
      let plan = getUserPlan();
      return plan == "premium" || plan == "enterprise";
    }

    // users/{userId}
    match /users/{userId} {
      allow read:  if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // workshops/{workshopId}
    match /workshops/{workshopId} {
      // Admin: acesso total ao próprio cadastro
      allow read:            if isAdmin() && isOwner(resource.data.userId);
      allow create:          if isAdmin()
                             && isOwner(request.resource.data.userId)
                             && (isPremiumOrEnterprise() || true);
      allow update, delete:  if isAdmin() && isOwner(resource.data.userId);

      // Oficina: lê apenas o próprio cadastro
      allow read: if isWorkshop()
                  && resource.data.workshopUserId == request.auth.uid;
    }

    // batches/{batchId}
    match /batches/{batchId} {
      // Admin: acesso total aos próprios lotes
      allow read:            if isAdmin() && isOwner(resource.data.userId);
      allow create:          if isAdmin()
                             && isOwner(request.resource.data.userId)
                             && (isPremiumOrEnterprise() || true);
      allow update, delete:  if isAdmin() && isOwner(resource.data.userId);

      // Oficina: lê apenas lotes atribuídos a ela
      allow read: if isWorkshop()
                  && resource.data.workshopId == request.auth.uid;
    }

    // Tudo mais negado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
