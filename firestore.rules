rules_version = '2';

// Publique no Firebase Console → Firestore → Regras (ou firebase deploy --only firestore:rules).
//
// Admin pode ser reconhecido por:
// - userType == "admin" em users/{uid}, ou
// - e-mail igual ao admin do app (mesmo critério do authService em código).

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Mesmo e-mail reservado que o cliente trata como admin (src/services/authService.ts)
    function isAdminEmail() {
      return request.auth != null
        && request.auth.token.email == 'costuraconectada@gmail.com';
    }

    function isAdmin() {
      return isSignedIn() && (
        isAdminEmail() ||
        (
          exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userType == 'admin'
        )
      );
    }

    function userTouchesSensitiveFields() {
      return request.resource.data.diff(resource.data).changedKeys().hasAny([
        'asaasSubaccountApiKey',
        'asaasSubaccountId',
        'asaasSubaccountWalletId',
        'asaasCustomerId',
        'asaasSubscriptionId',
        'subscriptionStatus',
        'subscriptionOverdueSince',
        'subscriptionNextDueDate',
        'subscriptionValue',
        'subscriptionLastWebhookEvent',
        'subscriptionLastPaymentDate',
        'ownerBatchCheckoutToken',
        'ownerWorkshopPayPaymentId'
      ]);
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && !userTouchesSensitiveFields();
      allow delete: if false;
    }

    match /workshops/{docId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Lotes: dono (userId) edita; oficina vinculada (linkedWorkshopUserId) só leitura —
    // aceitar convite é feito pela Cloud Function respondBatchInvite (admin SDK).
    match /batches/{docId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.linkedWorkshopUserId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /cuts/{docId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /receivePieces/{docId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /payments/{docId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && !('paidDate' in request.resource.data)
        && !('asaasPaymentStatus' in request.resource.data);
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && !request.resource.data.diff(resource.data).changedKeys().hasAny([
          'status',
          'paidDate',
          'asaasPaymentStatus'
        ]);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Notificações in-app: criadas só pelo backend (Admin SDK)
    match /inAppNotifications/{docId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create, delete: if false;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId;
    }
  }
}
