rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /** Helper: usuário autenticado */
    function isAuthenticated() {
      return request.auth != null;
    }

    /** Helper: ownership por userId */
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    /** Helper: plano do usuário salvo em users/{uid} */
    function getUserPlan() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.plan;
    }

    /** Helper: planos sem limite */
    function isPremiumOrEnterprise() {
      let plan = getUserPlan();
      return plan == "premium" || plan == "enterprise";
    }

    // =========================
    // users/{userId}
    // =========================
    // Leitura e escrita apenas para o próprio usuário autenticado.
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // =========================
    // workshops/{workshopId}
    // =========================
    match /workshops/{workshopId} {
      // Leitura: apenas dono do documento.
      allow read: if isOwner(resource.data.userId);

      // Criação:
      // - usuário autenticado
      // - userId do documento precisa ser o uid autenticado
      //
      // Observação importante:
      // Firestore Rules não oferecem agregação confiável de contagem para impor
      // "máximo 3 workshops" diretamente aqui sem infraestrutura adicional.
      // Portanto, o limite de quantidade para plano basic/ausente é enforçado
      // primariamente no frontend; no backend garantimos autenticação e ownership.
      allow create: if isAuthenticated()
                    && isOwner(request.resource.data.userId)
                    && (isPremiumOrEnterprise() || true);

      // Atualização e exclusão: apenas dono do documento.
      allow update, delete: if isOwner(resource.data.userId);
    }

    // =========================
    // batches/{batchId}
    // =========================
    match /batches/{batchId} {
      // Leitura: apenas dono do documento.
      allow read: if isOwner(resource.data.userId);

      // Criação:
      // - usuário autenticado
      // - userId do documento precisa ser o uid autenticado
      //
      // Observação importante:
      // O limite mensal (máx. 10 lotes/mês no basic) não pode ser enforçado
      // diretamente em Firestore Rules sem funções externas/infra adicional.
      // O controle primário é feito no frontend via getBatchCountThisMonth.
      allow create: if isAuthenticated()
                    && isOwner(request.resource.data.userId)
                    && (isPremiumOrEnterprise() || true);

      // Atualização e exclusão: apenas dono do documento.
      allow update, delete: if isOwner(resource.data.userId);
    }

    // Regra padrão: qualquer outra coleção não listada é negada.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
