# Não commite o arquivo `.env`. Use só em dev local com emulador, ou
# configure segredos com: firebase functions:secrets:set ASAAS_API_KEY

ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
ASAAS_API_URL=https://api.asaas.com/v3
PLATFORM_FEE_PERCENT=5
# Opcional: carteira Asaas para receber ~5% (split)
ASAAS_ADMIN_WALLET_ID=
