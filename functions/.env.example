# Não commite o arquivo `.env`. Use só em dev local com emulador, ou
# configure segredos com: firebase functions:secrets:set ASAAS_API_KEY

ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
# Produção: https://api.asaas.com/v3 | Sandbox (chave $aact_hmlg_...): https://api-sandbox.asaas.com/v3
ASAAS_API_URL=https://api-sandbox.asaas.com/v3
# Deve coincidir com MARKETPLACE_FEE_PERCENT no app (src/constants/marketplaceFee.ts)
PLATFORM_FEE_PERCENT=1
# Carteira da plataforma (UUID) — split marketplace / taxa
ASAAS_ADMIN_WALLET_ID=

# Mercado Pago (Secret Manager: MP_ACCESS_TOKEN, MP_CLIENT_SECRET) — emulador ou testes locais
# Produção: firebase functions:secrets:set MP_ACCESS_TOKEN (e MP_CLIENT_SECRET)
MP_ACCESS_TOKEN=
MP_CLIENT_SECRET=
